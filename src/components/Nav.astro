---
const { current = 'home' } = Astro.props;
const links = [
  { id: 'home', href: '/', label: 'home' },
  { id: 'skills', href: '/skills/', label: 'skills' },
  { id: 'projets', href: '/projets/', label: 'projets' },
  { id: 'parcours', href: '/parcours/', label: 'parcours' },
];
---

<nav>
  <div class="ni">
    <a class="logo" href="/">pld_</a>
    <div class="nr">
      {links.map(l => (
        <a class={`nl ${current === l.id ? 'a' : ''}`} href={l.href}>{l.label}</a>
      ))}
      <button class="th" id="thb" aria-label="Thème">☽</button>
    </div>
  </div>
</nav>

<style>
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    backdrop-filter: blur(16px); background: var(--nav);
    border-bottom: 1px solid var(--b);
  }
  .ni {
    max-width: 820px; margin: 0 auto; padding: 0 48px;
    height: 54px; display: flex; align-items: center; justify-content: space-between;
  }
  .logo { font-weight: 600; font-size: 15px; color: var(--ac); transition: opacity .2s; }
  .logo:hover { opacity: .7; }
  .nr { display: flex; gap: 4px; align-items: center; }
  .nl {
    font-size: 13px; color: var(--m); padding: 7px 14px;
    border-radius: 6px; transition: all .2s; text-decoration: none;
  }
  .nl:hover { color: var(--fg); background: var(--card); }
  .nl.a { color: var(--fg); background: var(--card); font-weight: 500; }
  .th {
    background: none; border: none; color: var(--m); cursor: pointer;
    font-size: 16px; padding: 7px 10px; border-radius: 6px; transition: all .2s;
  }
  .th:hover { color: var(--ac); background: var(--as); }
  @media (max-width: 768px) { .ni { padding: 0 28px; } }
  @media (max-width: 480px) { .ni { padding: 0 16px; } .nl { font-size: 11px; padding: 5px 8px; } }
</style>
