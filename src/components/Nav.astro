---
import type { Lang } from "../i18n/types";
import { getNavLinks, getAlternateLang, getAlternateUrl, localePath } from "../i18n/utils";
import type { RouteId } from "../i18n/types";

interface Props {
  current?: string;
  lang: Lang;
}
const { current = "home", lang } = Astro.props;

const links = getNavLinks(lang);
const altLang = getAlternateLang(lang);
const altUrl = getAlternateUrl(lang, (current as RouteId) || "home");
---

<nav class="fixed top-0 left-0 right-0 z-[100] backdrop-blur-[16px] bg-nav border-b border-border">
  <div class="px-12 h-14 flex items-center justify-between max-md:px-7 max-[480px]:px-4">
    <a class="font-bold text-[16px] text-accent transition-opacity duration-200 hover:opacity-70" href={localePath(lang, 'home')}>pld_</a>
    <div class="flex gap-8 items-center max-md:gap-5 max-[480px]:gap-3.5">
      {
        links.map((l) => (
          <a
            class={`nav-link max-[480px]:text-[11px] ${current === l.id ? "active" : ""}`}
            href={l.href}
          >
            {l.label}
          </a>
        ))
      }
      <a
        class="text-[11px] font-bold uppercase tracking-wider text-muted transition-colors duration-200 hover:text-accent"
        href={altUrl}
        aria-label={`Switch to ${altLang === 'en' ? 'English' : 'Français'}`}
      >
        {altLang}
      </a>
      <button
        class="bg-transparent border-none text-muted cursor-pointer w-9 h-9 rounded-full transition-all duration-200 flex items-center justify-center hover:text-accent hover:bg-accent-subtle"
        id="thb"
        aria-label="Theme"
      >
        <svg class="icon-sun w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <svg class="icon-moon w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </div>
  </div>
</nav>

<style>
  .icon-sun { display: none; }
  .icon-moon { display: block; }
  :global([data-th="d"]) .icon-sun { display: block; }
  :global([data-th="d"]) .icon-moon { display: none; }
</style>
