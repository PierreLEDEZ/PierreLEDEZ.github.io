---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<div class="max-w-[820px] mx-auto px-12 w-full min-h-screen flex flex-col max-md:px-7 max-[480px]:px-5">
  <div class="flex flex-col gap-8 pt-20 pb-6">
    <div class="sec-label text-[15px] text-accent font-bold tracking-[.15em] uppercase flex items-center gap-3 rv">
      {title}
    </div>
    <div>
      <slot />
    </div>
  </div>
  <div class="border-t border-border py-4 flex justify-between text-[11px] text-muted2 font-normal mt-auto max-md:flex-wrap max-md:gap-2">
    <slot name="status" />
  </div>
</div>
