---
interface Props {
  title: string;
  peek: string;
  href: string;
}
const { title, peek, href } = Astro.props;
---

<a class="pj-card rv group" href={href}>
  <h3 class="text-[clamp(24px,4vw,36px)] font-bold tracking-[-0.04em] text-ghost transition-colors duration-[400ms] group-hover:text-fg max-md:text-2xl max-[480px]:text-xl">
    {title}
  </h3>
  <div class="text-[11px] text-muted opacity-0 translate-y-1 transition-all duration-300 mt-0.5 group-hover:opacity-100 group-hover:translate-y-0">
    {peek}
  </div>
  <span class="absolute right-4 top-1/2 -translate-y-1/2 translate-x-3 text-[22px] text-accent transition-all duration-300 ease-[cubic-bezier(.4,0,.2,1)] opacity-0 pointer-events-none group-hover:translate-x-0 group-hover:opacity-100 max-md:hidden">
    →
  </span>
</a>
