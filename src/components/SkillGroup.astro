---
interface Props {
  category: string;
  items: string[];
  delay?: number;
}
const { category, items, delay } = Astro.props;
---

<div class="page-item" style={delay !== undefined ? `--d:${delay}s` : undefined}>
  <div class="text-[13px] text-accent tracking-[0.12em] uppercase mb-3 max-md:text-xs max-[480px]:text-[13px]">
    {category}
  </div>
  <div class="text-sm text-muted leading-[2.8] max-md:text-[13px] max-md:leading-[3] max-[480px]:text-[13px] max-[480px]:leading-[3.2]">
    {items.map((item) => (
      <span class="sk-sep text-fg font-normal transition-colors duration-200 cursor-default hover:text-accent">
        {item}
      </span>
    ))}
  </div>
</div>
