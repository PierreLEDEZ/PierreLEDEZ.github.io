---
interface Props {
  date: string;
  title: string;
  org: string;
  desc?: string;
}
const { date, title, org, desc } = Astro.props;
---

<div class="tl-dot rv py-[22px]">
  <div class="text-[11px] text-muted2 font-normal mb-[3px]">{date}</div>
  <div class="text-[17px] font-bold mb-[3px] max-[480px]:text-[15px]">{title}</div>
  <div class="text-sm text-accent font-normal">{org}</div>
  {desc && (
    <div class="text-[13px] text-muted font-normal mt-2 leading-[1.9] max-w-[500px] max-[480px]:text-xs">
      {desc}
    </div>
  )}
</div>
