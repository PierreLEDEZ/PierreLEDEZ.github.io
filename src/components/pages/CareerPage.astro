---
import Base from '../../layouts/Base.astro';
import PageSection from '../PageSection.astro';
import TimelineItem from '../TimelineItem.astro';
import type { Lang } from '../../i18n/types';
import { t, localePath } from '../../i18n/utils';
import { timeline } from '../../data/timeline';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const data = timeline[lang];
---

<Base title={`pld_ - ${t(lang, 'career.title')}`} current="career" lang={lang}>
  <PageSection title={t(lang, 'career.title')}>
    <div class="tl-line max-md:pl-6">
      {
        data.map((entry, i) => (
          <TimelineItem
            date={entry.date}
            title={entry.title}
            org={entry.org}
            desc={entry.desc}
            delay={0.7 + i * 0.08}
          />
        ))
      }
    </div>
    <Fragment slot="status">
      <span>{t(lang, 'career.path')}</span>
      <span>{t(lang, 'career.toeic')}</span>
      <a class="text-muted transition-colors duration-200 hover:text-accent" href={localePath(lang, 'home')}>{t(lang, 'career.back')}</a>
    </Fragment>
  </PageSection>
</Base>
