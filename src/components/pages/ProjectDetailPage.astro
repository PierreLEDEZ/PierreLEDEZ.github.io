---
import Base from '../../layouts/Base.astro';
import type { Lang } from '../../i18n/types';
import { t, localePath, projectPath } from '../../i18n/utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  lang: Lang;
  project: CollectionEntry<'projects'>;
}
const { lang, project } = Astro.props;
const { Content } = await project.render();
const d = project.data;
const projectsHref = localePath(lang, 'projects');
---

<Base title={`pld_ — ${d.title}`} current="projects" lang={lang}>
  <div class="max-w-[820px] mx-auto px-12 w-full min-h-screen flex flex-col max-md:px-7 max-[480px]:px-5">
    <div class="pt-20 pb-6">
      <a class="text-xs text-muted inline-flex items-center gap-1.5 transition-all duration-200 py-1.5 mb-8 hover:text-accent hover:-translate-x-1" href={projectsHref}>
        {t(lang, 'projects.allProjects')}
      </a>
      <h2 class="rv text-[clamp(24px,4vw,36px)] font-bold tracking-[-0.04em] mb-2.5 max-md:text-2xl max-[480px]:text-xl">
        {d.title}
      </h2>
      <div class="rv text-xs text-muted mb-7 flex gap-4 flex-wrap">
        <span>{d.ctx}</span>
        <span>{d.tags.length} {t(lang, 'projects.technologies')}</span>
      </div>

      {d.image ? (
        <div class="rv w-full aspect-video rounded-xl mb-7 overflow-hidden">
          <img class="w-full h-full object-cover" src={d.image} alt={d.title} />
        </div>
      ) : (
        <div class="rv img-empty-gradient w-full aspect-video rounded-xl mb-7 overflow-hidden relative"></div>
      )}

      <div class="rv text-sm text-muted font-normal leading-8 mb-7 max-w-[580px] [&_p]:mb-3">
        <Content />
      </div>

      <div class="rv flex gap-2 flex-wrap mb-7">
        {d.tags.map(tag => (
          <span class="text-xs px-3.5 py-2 bg-card rounded-lg text-muted transition-all duration-200 hover:bg-card-hover hover:-translate-y-px">
            {tag}
          </span>
        ))}
      </div>

      <div class="rv flex gap-2.5 flex-wrap">
        {d.github ? (
          <a class="pj-link" href={d.github} target="_blank">
            <svg viewBox="0 0 24 24"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
            {t(lang, 'projects.sourceCode')}
          </a>
        ) : (
          <span class="pj-link opacity-30 cursor-default pointer-events-none">
            <svg viewBox="0 0 24 24"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
            {t(lang, 'projects.private')}
          </span>
        )}
        {d.link && (
          <a class="pj-link" href={d.link} target="_blank">
            <svg viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            {t(lang, 'projects.viewProject')}
          </a>
        )}
      </div>
    </div>
    <div class="border-t border-border py-4 flex justify-between text-[11px] text-muted2 font-normal mt-auto max-md:flex-wrap max-md:gap-2">
      <span>{d.ctx}</span>
      <a class="text-muted transition-colors duration-200 hover:text-accent" href={projectsHref}>{t(lang, 'projects.back')}</a>
    </div>
  </div>
</Base>
