---
import Base from '../../layouts/Base.astro';
import PageSection from '../PageSection.astro';
import ProjectCard from '../ProjectCard.astro';
import type { Lang } from '../../i18n/types';
import { t, localePath, projectPath } from '../../i18n/utils';
import { getCollection } from 'astro:content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const allProjects = await getCollection('projects');
const projects = allProjects
  .filter((p) => p.data.lang === lang)
  .sort((a, b) => a.data.order - b.data.order);

// Strip lang prefix from slug (e.g. "en/plu-analysis" → "plu-analysis")
function stripLangPrefix(slug: string): string {
  return slug.replace(/^(en|fr)\//, '');
}
---

<Base title={`pld_ - ${t(lang, 'projects.title')}`} current="projects" lang={lang}>
  <PageSection title={t(lang, 'projects.title')}>
    {
      projects.map((p, i) => (
        <ProjectCard
          title={p.data.title}
          peek={`${p.data.ctx} — ${p.data.tags.slice(0, 3).join(', ')}`}
          href={projectPath(lang, stripLangPrefix(p.slug))}
          delay={0.7 + i * 0.08}
        />
      ))
    }
    <Fragment slot="status">
      <span>{projects.length} {t(lang, 'projects.count')}</span>
      <a class="text-muted transition-colors duration-200 hover:text-accent" href={localePath(lang, 'home')}>{t(lang, 'projects.back')}</a>
    </Fragment>
  </PageSection>
</Base>
