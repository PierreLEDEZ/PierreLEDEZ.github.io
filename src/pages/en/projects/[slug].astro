---
import ProjectDetailPage from '../../../components/pages/ProjectDetailPage.astro';
import { getVisibleProjects, stripLangPrefix } from '../../../lib/projects';

export async function getStaticPaths() {
  const enProjects = await getVisibleProjects('en');
  return enProjects.map((p) => ({
    params: { slug: stripLangPrefix(p.slug) },
    props: { project: p },
  }));
}

const { project } = Astro.props;
---
<ProjectDetailPage lang="en" project={project} />
