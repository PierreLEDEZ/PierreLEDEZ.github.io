---
import ProjectDetailPage from '../../../components/pages/ProjectDetailPage.astro';
import { getVisibleProjects, stripLangPrefix } from '../../../lib/projects';

export async function getStaticPaths() {
  const frProjects = await getVisibleProjects('fr');
  return frProjects.map((p) => ({
    params: { slug: stripLangPrefix(p.slug) },
    props: { project: p },
  }));
}

const { project } = Astro.props;
---
<ProjectDetailPage lang="fr" project={project} />
