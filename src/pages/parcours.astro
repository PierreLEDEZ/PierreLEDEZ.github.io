---
import Base from "../layouts/Base.astro";
import PageSection from "../components/PageSection.astro";
import TimelineItem from "../components/TimelineItem.astro";
import { timeline } from "../data/timeline";
---

<Base title="pld_ - Parcours" current="parcours">
  <PageSection title="Parcours">
    <div class="tl-line max-md:pl-6">
      {
        timeline.map((t, i) => (
          <TimelineItem
            date={t.date}
            title={t.title}
            org={t.org}
            desc={t.desc}
            delay={0.7 + i * 0.08}
          />
        ))
      }
    </div>
    <Fragment slot="status">
      <span>ENIB → CERV → Siradel</span>
      <span>TOEIC 935</span>
      <a class="text-muted transition-colors duration-200 hover:text-accent" href="/">← retour</a>
    </Fragment>
  </PageSection>
</Base>
