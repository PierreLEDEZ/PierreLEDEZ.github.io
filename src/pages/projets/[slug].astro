---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const d = project.data;
---

<Base title={`pld_ — ${d.title}`} current="projets">
  <div class="w">
    <div class="detail">
      <a class="back" href="/projets/">← tous les projets</a>
      <h2 class="rv">{d.title}</h2>
      <div class="meta rv">
        <span>{d.ctx}</span>
        <span>{d.tags.length} technologies</span>
      </div>

      {d.image ? (
        <div class="img rv">
          <img src={d.image} alt={d.title} />
        </div>
      ) : (
        <div class="img img-empty rv"></div>
      )}

      <div class="desc rv">
        <Content />
      </div>

      <div class="tags rv">
        {d.tags.map(t => <span>{t}</span>)}
      </div>

      <div class="links rv">
        {d.github ? (
          <a class="pj-link" href={d.github} target="_blank">
            <svg viewBox="0 0 24 24"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
            Code source
          </a>
        ) : (
          <span class="pj-link disabled">
            <svg viewBox="0 0 24 24"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
            Privé
          </span>
        )}
        {d.link && (
          <a class="pj-link" href={d.link} target="_blank">
            <svg viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            Voir le projet
          </a>
        )}
      </div>
    </div>
    <div class="status" style="margin-top:48px">
      <span>{d.ctx}</span>
      <a href="/projets/">← retour</a>
    </div>
  </div>
</Base>

<style>
  .detail { padding: 100px 0 40px; }
  .back {
    font-size: 12px; color: var(--m); display: inline-flex; align-items: center;
    gap: 6px; transition: all .2s; padding: 6px 0; margin-bottom: 32px;
  }
  .back:hover { color: var(--ac); transform: translateX(-4px); }
  h2 {
    font-size: clamp(24px,4vw,36px); font-weight: 700;
    letter-spacing: -.04em; margin-bottom: 10px;
  }
  .meta {
    font-size: 12px; color: var(--m); margin-bottom: 28px;
    display: flex; gap: 16px; flex-wrap: wrap;
  }
  .img {
    width: 100%; aspect-ratio: 16/9; border-radius: 12px; margin-bottom: 28px;
    overflow: hidden;
  }
  .img img { width: 100%; height: 100%; object-fit: cover; }
  .img-empty {
    background: linear-gradient(135deg, var(--img1) 0%, var(--img2) 40%, var(--img1) 60%, var(--img2) 100%);
    position: relative;
  }
  .img-empty::after {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at center, transparent 40%, var(--bg) 100%);
  }
  .desc {
    font-size: 14px; color: var(--m); font-weight: 300; line-height: 2;
    margin-bottom: 28px; max-width: 580px;
  }
  .desc :global(p) { margin-bottom: 12px; }
  .tags { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 28px; }
  .tags span {
    font-size: 12px; padding: 8px 14px; background: var(--card);
    border-radius: 8px; color: var(--m); transition: all .2s;
  }
  .tags span:hover { background: var(--ch); transform: translateY(-1px); }
  .links { display: flex; gap: 10px; flex-wrap: wrap; }
  .pj-link {
    display: inline-flex; align-items: center; gap: 8px; font-size: 12px;
    color: var(--m); padding: 10px 20px; border: 1px solid var(--b);
    border-radius: 100px; transition: all .3s cubic-bezier(.4,0,.2,1);
  }
  .pj-link:hover { color: var(--ac); border-color: var(--ac); background: var(--as); transform: translateY(-2px); }
  .pj-link svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
  .pj-link.disabled { opacity: .3; cursor: default; pointer-events: none; }
  @media (max-width: 768px) { h2 { font-size: 24px; } .img { aspect-ratio: 4/3; } }
  @media (max-width: 480px) { h2 { font-size: 20px; } }
</style>
