---
import Base from "../../layouts/Base.astro";
import PageSection from "../../components/PageSection.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Base title="pld_ - Projets" current="projets">
  <PageSection title="Projets">
    {
      projects.map((p) => (
        <ProjectCard
          title={p.data.title}
          peek={`${p.data.ctx} — ${p.data.tags.slice(0, 3).join(", ")}`}
          href={`/projets/${p.slug}/`}
        />
      ))
    }
    <Fragment slot="status">
      <span>{projects.length} projets</span>
      <a class="text-muted transition-colors duration-200 hover:text-accent" href="/">← retour</a>
    </Fragment>
  </PageSection>
</Base>
