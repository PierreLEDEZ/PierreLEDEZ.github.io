---
import Base from "../../layouts/Base.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Base title="pld_ - Projets" current="projets">
  <div class="max-w-[820px] mx-auto px-12 w-full min-h-screen flex flex-col max-md:px-7 max-[480px]:px-5">
    <div class="flex flex-col pt-20 pb-6">
      <div class="sec-label text-[15px] text-accent font-bold tracking-[.15em] uppercase mb-[22px] flex items-center gap-3 rv">
        Projets
      </div>
      {
        projects.map((p) => (
          <ProjectCard
            title={p.data.title}
            peek={`${p.data.ctx} — ${p.data.tags.slice(0, 3).join(", ")}`}
            href={`/projets/${p.slug}/`}
          />
        ))
      }
    </div>
    <div class="border-t border-border py-4 flex justify-between text-[11px] text-muted2 font-normal mt-auto max-md:flex-wrap max-md:gap-2">
      <span>{projects.length} projets</span>
      <a class="text-muted transition-colors duration-200 hover:text-accent" href="/">← retour</a>
    </div>
  </div>
</Base>
